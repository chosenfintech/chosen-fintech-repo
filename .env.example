
NODE_ENV="your development environment"
DATABASE_URL="database url, example: postgresql://nuru:[db-password]@localhost:5432/db_name"
SESSION_SECRET="your auth session secret"

ADMIN_PASSWORD="initial admin password"
ADMIN_FULLNAME="initial admin fullname"
ADMIN_PHONE="initial admin phone number"
ADMIN_EMAIL="initial admin email"
ADMIN_SEED_ENABLED="a boolean for whether seed or not"

NEXT_PUBLIC_BASE_URL="site url"

CLOUDINARY_CLOUD_NAME="your cloudinary name"
CLOUDINARY_API_KEY="your cloudinary api key"
CLOUDINARY_API_SECRET="your api secret"

NEXT_PUBLIC_TINYMCE_API_KEY="your tiny mce api key here"

UPSTASH_REDIS_REST_URL='your apstash redis url'
UPSTASH_REDIS_REST_TOKEN='your upstash redis rest token'


