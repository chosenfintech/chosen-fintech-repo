generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  fullname         String
  phone            String?
  password         String
  isAdmin          Boolean  @default(false)
  twoFactorEnabled Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  posts            Post[]
  events           Event[]
  guides           Guide[]
  projects         Project[]

  securityTokens UserSecurityToken[]

  @@index([email])
  @@index([id])
}

model Post {
  id          String    @id @default(uuid())
  slug        String    @unique @db.VarChar(255)
  title       String    @db.VarChar(255)
  excerpt     String    @db.VarChar(500)
  content     String
  publishDate DateTime?
  readTime    String    @db.VarChar(50)
  coverImage  String?   @db.VarChar(255)
  isPublished Boolean   @default(false)
  isFeatured  Boolean?  @default(false)

  // Relations`
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([publishDate])
  @@index([categoryId])
  @@index([authorId])
  @@index([isPublished])
  @@index([id])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts Post[]

  @@index([id])
  @@index([name])
}

model Event {
  id          String    @id @default(uuid())
  slug        String    @unique @db.VarChar(255)
  title       String    @db.VarChar(255)
  excerpt     String    @db.VarChar(500)
  content     String
  publishDate DateTime?
  readTime    String    @db.VarChar(50)
  coverImage  String?   @db.VarChar(255)
  isPublished Boolean   @default(false)
  isFeatured  Boolean?  @default(false)

  // Event-specific details
  eventDate DateTime?
  location  String?   @db.VarChar(255)
  startTime String?   @db.VarChar(50)
  endTime   String?   @db.VarChar(50)

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String?
  category   EventCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([eventDate])
  @@index([publishDate])
  @@index([categoryId])
  @@index([authorId])
  @@index([isPublished])
  @@index([id])
}

model EventCategory {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events Event[]

  @@index([id])
  @@index([name])
}

enum GuideLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Guide {
  id          String     @id @default(uuid())
  slug        String     @unique @db.VarChar(255)
  title       String     @db.VarChar(255)
  description String     @db.VarChar(500)
  content     String
  image       String?    @db.VarChar(500)
  level       GuideLevel @default(BEGINNER)
  readTime    String     @db.VarChar(50)
  isPublished Boolean    @default(false)
  isFeatured  Boolean?   @default(false)
  publishDate DateTime?

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([level])
  @@index([publishDate])
  @@index([authorId])
  @@index([isPublished])
  @@index([id])
}

model Project {
  id          String    @id @default(uuid())
  slug        String    @unique @db.VarChar(255)
  title       String    @db.VarChar(255)
  description String    @db.VarChar(500)
  content     String
  imageUrl    String?   @db.VarChar(500)
  readTime    String    @db.VarChar(50)
  isPublished Boolean   @default(false)
  isFeatured  Boolean?  @default(false)
  publishDate DateTime?

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([publishDate])
  @@index([authorId])
  @@index([isPublished])
  @@index([id])
}

model GalleryCategory {
  id         String   @id @default(uuid())
  name       String   @unique @db.VarChar(100)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  photos GalleryPhoto[]

  @@index([id])
  @@index([name])
  @@index([isFeatured])
}

model GalleryPhoto {
  id          String          @id @default(uuid())
  url         String          @db.VarChar(500)
  altText     String?         @db.VarChar(255)
  caption     String?         @db.VarChar(500)
  isPublished Boolean         @default(false)
  categoryId  String
  category    GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([id])
  @@index([categoryId])
  @@index([isPublished])
}

enum UserSecurityTokenType {
  TWO_FACTOR_LOGIN // 6-digit email OTP challenged at login
  TWO_FACTOR_SETUP // 6-digit email OTP confirming 2FA enablement
  PASSWORD_RESET // long random token embedded in the email reset link
}

model UserSecurityToken {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  /// sha256 of the plain code — the plain value is never stored.
  tokenHash String                @unique
  type      UserSecurityTokenType

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}
